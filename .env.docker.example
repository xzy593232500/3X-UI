# Copy this file to .env.docker if you want to keep Docker settings outside
# docker-compose.yml, then run:
#   docker compose --env-file .env.docker up -d --build

# Local image name built by docker compose.
XUI_IMAGE=3x-ui-jbhd:local

# Container timezone.
TZ=Asia/Shanghai

# Persistent data directories on the host.
XUI_DATA_DIR=./db
XUI_CERT_DIR=./cert

# Runtime switches.
XRAY_VMESS_AEAD_FORCED=false
XUI_ENABLE_FAIL2BAN=true
