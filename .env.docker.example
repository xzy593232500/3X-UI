# Copy this file to .env.docker if you want to keep Docker settings outside
# docker-compose.yml, then run:
#   docker compose --env-file .env.docker up -d --build

# Local image name built by docker compose.
XUI_IMAGE=3x-ui-jbhd:local

# Container timezone.
TZ=Asia/Shanghai

# Persistent data directories on the host.
XUI_DATA_DIR=./db
XUI_CERT_DIR=./cert

# Runtime switches.
XRAY_VMESS_AEAD_FORCED=false
XUI_ENABLE_FAIL2BAN=true

# Optional public URL used when the customer subscription page generates
# customer subscription links. Leave empty to use the current panel host.
# Example: XUI_PUBLIC_SUB_BASE_URL=http://your-server-ip
XUI_PUBLIC_SUB_BASE_URL=

# Upstream subscription relay mode.
# relay: customer nodes connect to this server first, then this server connects upstream.
# direct: publish upstream node links directly.
XUI_UPSTREAM_RELAY_MODE=relay

# Public host used inside relayed node links. Leave empty to infer it from
# XUI_PUBLIC_SUB_BASE_URL or the request host.
XUI_RELAY_PUBLIC_HOST=

# Relay ports are randomly assigned per upstream node inside this range and
# then kept stable in the database. Open this TCP range on your server
# firewall/security group.
XUI_RELAY_PORT_MIN=30000
XUI_RELAY_PORT_MAX=50000
